# Django core
SECRET_KEY=change-me-to-a-long-random-string
DJANGO_SETTINGS_MODULE=schoolmgmt_project.settings.dev

# Allowed hosts (comma-separated, prod only)
ALLOWED_HOSTS=yourschool.onrender.com,www.yourschool.com

# Database (leave blank for dev — SQLite is used automatically)
DB_NAME=school_db
DB_USER=school_user
DB_PASSWORD=strong-password-here
DB_HOST=localhost
DB_PORT=5432

# Africa's Talking
AT_USERNAME=sandbox
AT_API_KEY=your-africastalking-api-key
AT_SENDER_ID=
AT_SANDBOX=True

# Email (optional for MVP)
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_HOST_USER=yourschool@gmail.com
EMAIL_HOST_PASSWORD=your-app-password
